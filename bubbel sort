#include <stdio.h>

void bubblesort(int a[] , int n){
    int temp;
    for(int i =0;i<n-1;i++){
        for(int j=0;j<n-i-1;j++){
            if(a[j] > a[j+1]){
                temp=a[j];
                a[j]=a[j+1];
                a[j+1]= temp;
            }
        }
    }
}

int display(int a[],int n){
    for(int i=0;i<n;i++){
        printf("%d",a[i]);
    }
    printf("\n");
}

int main() {
    int n;
    printf("Enter the no of elements in the array:");
    scanf("%d",&n);
    
    int a[n];
    
    printf("Enter the elements in the array");
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    
    printf("The unsorted array:");
    display(a,n);
    
    bubblesort(a,n);
    
    printf("the bubble sort final array is:");
    display(a,n);

    return 0;
}
